<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Expenses"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0B7A34"
            android:layout_marginBottom="15dp" />

        <Button
            android:id="@+id/btnLoadAllExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load All Expenses"
            android:backgroundTint="#0B7A34"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvExpenseResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All expenses will appear here"
            android:textSize="16sp"
            android:paddingTop="20dp" />

    </LinearLayout>
</ScrollView>