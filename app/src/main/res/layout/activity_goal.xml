<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F1F8F4">

    <TextView
        android:text="🎯 Monthly Goals"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#0B7A34"
        android:layout_marginBottom="25dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <EditText
        android:id="@+id/etMinGoal"
        android:hint="⬇️ Minimum Goal"
        android:inputType="numberDecimal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <EditText
        android:id="@+id/etMaxGoal"
        android:hint="⬆️ Maximum Goal"
        android:inputType="numberDecimal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp" />

    <SeekBar
        android:id="@+id/seekGoal"
        android:max="10000"
        android:progress="3000"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/tvSeekValue"
        android:text="💡 Goal preview: R3000"
        android:textSize="18sp"
        android:textColor="#333333"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/btnSaveGoals"
        android:text="💾 Save Goals"
        android:backgroundTint="#F9A825"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>